<Window x:Class="timer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:timer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Border BorderBrush="#4682B4" BorderThickness="2" CornerRadius="8" Margin="10" Background="White">
        <StackPanel Margin="20" VerticalAlignment="Center">

            <TextBlock Text="Налаштування таймера" FontSize="16" FontWeight="SemiBold" 
                       Foreground="#4682B4" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="Час (у хвилинах):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="MinutesTextBox" Width="60" TextAlignment="Center" FontSize="14" Padding="2"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Content="Старт" Width="80" Height="28" Click="StartButton_Click" Margin="0,0,15,0" Background="LightGreen"/>
                <Button Content="Пауза" Width="60" Height="28" Click="PauseButton_Click" Margin="0,0,15,0" Background="LightGray"/>
                <Button Content="Стоп" Width="80" Height="28" Click="StopButton_Click" Background="IndianRed"/>
                
                
            </StackPanel>

            <Separator Margin="10,0,10,15" Background="#ADD8E6"/>

            <TextBlock Text="Залишилось часу:" HorizontalAlignment="Center" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBlock x:Name="TimeDisplayTextBlock" Text="00:00:00" FontSize="36" FontWeight="Bold" 
                       Foreground="#333333" HorizontalAlignment="Center"/>

        </StackPanel>
    </Border>
</Window>
